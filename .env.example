# オンライン機能（1 で有効。未設定ならオフライン同等）
NEXT_PUBLIC_ONLINE=1

# 本番で API が別オリジンのときだけ指定
# NEXT_PUBLIC_API_BASE=

NEXT_PUBLIC_PRESENCE_POLL_MS=60000

# NEXT_PUBLIC_PRIVACY_CONTACT=your@example.com

# WORKER_DEV_ORIGIN=http://localhost:8787
# orb を presence に連動（0 で固定数）
# NEXT_PUBLIC_ORB_LINK=0
# NEXT_PUBLIC_ORB_STEP_MS=1200

# Worker 側（wrangler.toml / secrets）— docs/design/09-security.md
# ALLOWED_ORIGINS=https://your-app.pages.dev
# IP_THROTTLE_WINDOW_SEC=60
# IP_THROTTLE_MAX=120
