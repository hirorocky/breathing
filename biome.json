{
  "$schema": "./stack-chan/firmware/node_modules/@biomejs/biome/configuration_schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": ["overlay/mods/**/*.ts"],
    "ignoreUnknown": false
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 120
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "preset": "all",
        "noNodejsModules": "off",
        "noUndeclaredDependencies": "off",
        "noUndeclaredVariables": "off",
        "noUnresolvedImports": "off",
        "useQwikValidLexicalScope": "off"
      },
      "performance": {
        "preset": "all",
        "noAwaitInLoops": "off"
      },
      "security": {
        "preset": "all",
        "noSecrets": "off"
      },
      "suspicious": {
        "preset": "all"
      },
      "style": {
        "noDefaultExport": "off",
        "useNodejsImportProtocol": "off"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "asNeeded"
    }
  },
  "json": {
    "formatter": {
      "lineWidth": 80
    }
  }
}
